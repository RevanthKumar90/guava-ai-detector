<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 🌿 Clean soft card -->
    <solid android:color="@color/cardWhite"/>

    <!-- Rounded corners -->
    <corners android:radius="20dp"/>

    <!-- Ultra subtle border -->
    <stroke
        android:width="0.8dp"
        android:color="#E3EFE6"/>

    <!-- Inner padding -->
    <padding
        android:left="16dp"
        android:right="16dp"
        android:top="16dp"
        android:bottom="16dp"/>

</shape>
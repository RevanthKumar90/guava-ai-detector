<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#40FFFFFF">  <!-- slightly better ripple -->

    <item>
        <selector>

            <!-- 🔥 Pressed State -->
            <item android:state_pressed="true">
                <shape>
                    <gradient
                        android:startColor="#1B5E20"
                        android:endColor="#2E7D32"
                        android:angle="0"/>

                    <corners android:radius="28dp"/>

                    <!-- subtle inner shadow feel -->
                    <stroke
                        android:width="1dp"
                        android:color="#33000000"/>
                </shape>
            </item>

            <!-- 🌿 Default State -->
            <item>
                <shape>

                    <!-- smooth gradient (same colors, better blend) -->
                    <gradient
                        android:startColor="#2E7D32"
                        android:endColor="#66BB6A"
                        android:angle="0"/>

                    <corners android:radius="28dp"/>

                    <!-- softer border -->
                    <stroke
                        android:width="1dp"
                        android:color="#30FFFFFF"/>

                </shape>
            </item>

        </selector>
    </item>

</ripple>